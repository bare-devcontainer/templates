{
  "name": "Terraform",
  "image": "ghcr.io/bare-devcontainer/terraform:${templateOption:imageVariant}",
  "remoteUser": "dev",
  "init": true,
  "containerEnv": {
    "TF_PLUGIN_CACHE_DIR": "/home/dev/.terraform.d/plugin-cache"
  },
  "mounts": [
    // Persist Terraform's provider plugin cache across rebuilds to avoid re-downloading providers.
    {
      "source": "${devcontainerId}-terraform-plugin-cache",
      "target": "/home/dev/.terraform.d/plugin-cache",
      "type": "volume"
    }
  ],
  // Uncomment the following options to enable the debugger.
  // "capAdd": ["SYS_PTRACE"],
  // "securityOpt": ["seccomp=unconfined"],
  "customizations": {
    "vscode": {
      "extensions": [
        "hashicorp.terraform"
      ]
    }
  }
}
