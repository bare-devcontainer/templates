{
  "name": "Debian",
  // Recommended: pin to a digest (e.g. "ghcr.io/bare-devcontainer/debian:trixie@sha256:<digest>").
  // See https://github.com/bare-devcontainer/templates#pinning-images-to-a-digest
  "image": "ghcr.io/bare-devcontainer/debian:${templateOption:imageVariant}",
  "remoteUser": "dev",
  "init": true
  // If you use VS Code, uncomment the following to open $EDITOR/$VISUAL/$GIT_EDITOR (e.g. `git commit`) in a VS Code tab:
  // "remoteEnv": {
  //   "VISUAL": "code --wait",
  //   "EDITOR": "code --wait",
  //   "GIT_EDITOR": "code --wait"
  // }
}
