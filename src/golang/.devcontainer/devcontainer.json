{
  "name": "Go",
  // Recommended: pin to a digest (e.g. "ghcr.io/bare-devcontainer/golang:1.26-trixie@sha256:<digest>").
  // See https://github.com/bare-devcontainer/templates#pinning-images-to-a-digest
  "image": "ghcr.io/bare-devcontainer/golang:${templateOption:imageVariant}",
  "remoteUser": "dev",
  "runArgs": ["--cap-drop=ALL", "--security-opt=no-new-privileges"],
  "init": true,
  // If you use VS Code, uncomment the following to open $EDITOR/$VISUAL/$GIT_EDITOR (e.g. `git commit`) in a VS Code tab:
  // "remoteEnv": {
  //   "VISUAL": "code --wait",
  //   "EDITOR": "code --wait",
  //   "GIT_EDITOR": "code --wait"
  // },
  "mounts": [
    // Persist the Go module cache (GOMODCACHE) across rebuilds to avoid re-downloading modules.
    {
      "source": "${devcontainerId}-golang-pkg-mod",
      "target": "/home/dev/go/pkg/mod",
      "type": "volume"
    },
    // Persist the Go build cache (GOCACHE) across rebuilds to speed up incremental builds.
    {
      "source": "${devcontainerId}-golang-build-cache",
      "target": "/home/dev/.cache/go-build",
      "type": "volume"
    }
  ],
  // Uncomment the following options to enable the debugger.
  // "capAdd": ["SYS_PTRACE"],
  // "securityOpt": ["seccomp=unconfined"],
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go"
      ],
      "settings": {
        "go.toolsManagement.autoUpdate": false,
        "go.toolsManagement.checkForUpdates": "local",
        "[go]": {
          "editor.defaultFormatter": "golang.go",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        },
        "gopls": {
          "ui.semanticTokens": true
        }
      }
    }
  }
}
