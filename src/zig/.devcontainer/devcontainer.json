{
  "name": "Zig",
  "image": "ghcr.io/bare-devcontainer/zig:${templateOption:imageVariant}",
  "runArgs": [
    // Always pull the latest image to receive security updates regularly.
    "--pull=always"
  ],
  "remoteUser": "dev",
  "updateRemoteUserUID": false,
  "init": true,
  "mounts": [
    // Persist the Zig global cache across rebuilds to avoid re-downloading packages and recompiling dependencies.
    {
      "source": "${devcontainerId}-zig-global-cache",
      "target": "/home/dev/.cache/zig",
      "type": "volume"
    }
  ],
  // Uncomment the following options to enable the debugger.
  // "capAdd": ["SYS_PTRACE"],
  // "securityOpt": ["seccomp=unconfined"],
  "customizations": {
    "vscode": {
      "extensions": [
        "ziglang.vscode-zig"
      ],
      "settings": {
        "zig.path": "/usr/local/zig/zig",
        "zig.zls.path": "/usr/local/bin/zls",
        "zig.zls.enabled": "on",
        "[zig]": {
          "editor.suggest.insertMode": "replace",
          "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
          }
        },
        "editor.semanticTokenColorCustomizations": {
          "rules": {
            "*.deprecated": {
              "strikethrough": true
            }
          }
        }
      }
    }
  }
}
