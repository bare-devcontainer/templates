{
  "name": "Zig",
  "image": "ghcr.io/bare-devcontainer/zig:${templateOption:imageVariant}",
  "remoteUser": "dev",
  "init": true,
  // Uncomment the following options to enable the debugger.
  // "capAdd": ["SYS_PTRACE"],
  // "securityOpt": ["seccomp=unconfined"],
  "customizations": {
    "vscode": {
      "extensions": [
        "ziglang.vscode-zig"
      ],
      "settings": {
        "[zig]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "ziglang.vscode-zig"
        }
      }
    }
  }
}
