{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_UPDATES": "1"
  },
  "permissions": {
    "allow": [
      "Read(//workspaces)",
      "Edit(//workspaces)"
    ],
    "deny": [
      "Edit(//**/.env)",
      "Edit(//**/.git/**)",
      "Bash(sudo *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git remote *)"
    ]
  }
}
